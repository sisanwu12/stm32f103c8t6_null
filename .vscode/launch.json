{
  "configurations": [
    {
      "name": "Debug with OpenOCD",
      "type": "cortex-debug",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "executable": "${config:cmake.buildDirectory}/null_proj.elf",
      "preLaunchTask": "Debug Build",
      "device": "STM32F103C8T6",
      "servertype": "openocd",
      "serverpath": "${workspaceFolder}/.vscode/nix-openocd",
      "gdbPath": "${workspaceFolder}/.vscode/nix-arm-none-eabi-gdb",
      "configFiles": [
        "interface/cmsis-dap.cfg",
        "target/stm32f1x.cfg"
      ],
      "searchDir": [],
      "interface": "swd",
      "runToEntryPoint": "main",
      "svdFile": "${config:cmake.sourceDirectory}/STM32F103xx.svd",
      "showDevDebugOutput": "none"
    }
  ]
}
