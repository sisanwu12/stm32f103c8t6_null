{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "CMake Configure",
      "type": "shell",
      "command": "${workspaceFolder}/.vscode/nix-cmake",
      "args": [
        "--fresh",
        "-S",
        "${config:cmake.sourceDirectory}",
        "-B",
        "${config:cmake.buildDirectory}",
        "-G",
        "${config:cmake.generator}",
        "-DCMAKE_TOOLCHAIN_FILE=${config:cmake.sourceDirectory}/arm-gnu-none-eabi.cmake"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "CMake Build",
      "type": "shell",
      "command": "${workspaceFolder}/.vscode/nix-cmake",
      "args": [
        "--build",
        "${config:cmake.buildDirectory}",
        "--target",
        "all"
      ],
      "dependsOn": [
        "CMake Configure"
      ],
      "dependsOrder": "sequence",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": {
        "owner": "c",
        "source": "arm-none-eabi-gcc",
        "fileLocation": [
          "absolute"
        ],
        "pattern": {
          "regexp": "^(.*?):(\\d+):(\\d+):\\s+(warning|error|note):\\s+(.*)$",
          "file": 1,
          "line": 2,
          "column": 3,
          "severity": 4,
          "message": 5
        }
      }
    },
    {
      "label": "Debug Build",
      "dependsOn": [
        "CMake Build"
      ],
      "dependsOrder": "sequence",
      "problemMatcher": []
    },
    {
      "label": "Flash",
      "type": "shell",
      "command": "${workspaceFolder}/.vscode/nix-openocd",
      "args": [
        "-f",
        "interface/cmsis-dap.cfg",
        "-f",
        "target/stm32f1x.cfg",
        "-c",
        "program ${config:cmake.buildDirectory}/null_proj.elf verify reset exit"
      ],
      "dependsOn": [
        "CMake Build"
      ],
      "dependsOrder": "sequence",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Clean",
      "type": "shell",
      "command": "${workspaceFolder}/.vscode/nix-cmake",
      "args": [
        "-E",
        "rm",
        "-rf",
        "${config:cmake.buildDirectory}",
        "${workspaceFolder}/.cache"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": [],
      "options": {
        "cwd": "${workspaceFolder}"
      }
    }
  ]
}
